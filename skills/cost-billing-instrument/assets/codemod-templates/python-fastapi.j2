{# Python + FastAPI codemod template for /cost-billing-instrument
   Variables expected:
     entry.pattern              — sibling-pair | usage-only | cost-only
     entry.event_type           — e.g. "completion.delivered"
     entry.workflow_id          — stable identifier
     entry.idempotency_anchor   — { handler, path_param, confidence }
     entry.refund_unit          — { unit, derivation }
     entry.cost_workflow_ids    — list of cost-event workflow_ids that feed this usage event
     trace_context_source       — "otel-via-fastapi-instrumentation" | "datadog" | ...
     attribution_keys           — list of available attribution keys at this site
     is_brownfield              — bool; true if customer already has OTel
#}
{% if entry.pattern == "sibling-pair" %}
# ─────────────────────────────────────────────────────────────────────────────
# moolabs SDK inserts (sibling-pair pattern)
# usage event → emit_usage_event_safe() → client.usage.ingest_events()
# cost events → emit_cost_event_safe() — SDK if capable (client.cost.ingest_events_batch),
#               OTel-span fallback if not. Verified per Phase 1.5 snapshot.
#
# Both call paths go through the per-service helper (moolabs_client.py).
# NEVER instantiate Moolabs() inline — see Phase 2 of cost-billing-instrument SKILL.md.
#
# SDK is blocking by design (~35ms typical round-trip). See PR description for
# latency profile. v1 default is Option B (blocking + documented).
# ─────────────────────────────────────────────────────────────────────────────

# All SDK + OTel-span emission goes through the per-service helper.
# NEVER instantiate Moolabs() inline here — see Phase 2 of cost-billing-instrument SKILL.md.
from app.services.moolabs_client import emit_usage_event_safe, emit_cost_event_safe

# Cost-event side of the sibling pair: enrich the active OTel span.
# emit_cost_event_safe handles fail-open + no-recording-span no-op internally.
emit_cost_event_safe(
    kind="{{ entry.cost_kind | default('unknown') }}",
    {% if "tenant_id" in attribution_keys %}tenant_id=request.state.tenant_id,
    {% endif %}{% if "consumer_agent" in attribution_keys %}consumer_agent={{ entry.consumer_agent_source | default("None") }},
    {% endif %}{% if entry.cost_micros_source %}cost_micros={{ entry.cost_micros_source }},
    {% endif %}attributes={
        "workflow_id": "{{ entry.workflow_id }}",
        "event_type": "{{ entry.event_type }}",
        {% for cost_wf in entry.cost_workflow_ids %}"upstream.{{ loop.index }}.workflow_id": "{{ cost_wf }}",
        {% endfor %}{% if "request_id" in attribution_keys %}"request.id": request.state.request_id,
        {% endif %}{% if "customer_id" in attribution_keys %}"customer.id": str(customer_id),
        {% endif %}{% if "feature_id" in attribution_keys %}"feature.id": "{{ entry.workflow_id.split('.')[1] }}",
        {% endif %}
    },
)

# Usage event — sibling-pair primary emission.
# REVIEW: idempotency key derivation (confidence={{ entry.idempotency_anchor.confidence }})
emit_usage_event_safe(
    event_type="{{ entry.event_type }}",
    subject=str({{ entry.idempotency_anchor.path_param if "customer_id" in attribution_keys else "request.state.request_id" }}),
    data={
        "quantity": {{ entry.refund_unit.derivation }},
        "unit": "{{ entry.refund_unit.unit }}",
    },
    {% if "request_id" in attribution_keys %}correlation_id=request.state.request_id,{% endif %}
)
except Exception as _moolabs_err:
    # Log + continue — don't fail the user-facing handler on telemetry failure
    import logging as _moolabs_log
    _moolabs_log.getLogger("moolabs").warning(
        "ingest_events failed for %s: %s", "{{ entry.workflow_id }}", _moolabs_err
    )

{% elif entry.pattern == "usage-only" %}
# ─────────────────────────────────────────────────────────────────────────────
# moolabs SDK insert (usage-only pattern)
# Single usage event; no cost-bearing call at this site.
# ─────────────────────────────────────────────────────────────────────────────

{% if not is_brownfield %}from moolabs import Moolabs as _MoolabsClient
_moolabs_client = _MoolabsClient(api_key=os.environ["MOOLABS_API_KEY"]){% endif %}

_moolabs_idempotency_key = f"{{ entry.idempotency_anchor.handler }}.{{ '{' }}{{ entry.idempotency_anchor.path_param }}{{ '}' }}.{int(time.time())}"

try:
    _moolabs_client.meter.events.ingest_events([{
        "id": _moolabs_idempotency_key,
        "type": "{{ entry.event_type }}",
        "subject": str({{ entry.idempotency_anchor.path_param }}),
        "time": datetime.utcnow().isoformat() + "Z",
        "data": {
            "quantity": {{ entry.refund_unit.derivation }},
            "unit": "{{ entry.refund_unit.unit }}",
        },
    }])
except Exception as _moolabs_err:
    import logging as _moolabs_log
    _moolabs_log.getLogger("moolabs").warning(
        "ingest_events failed for %s: %s", "{{ entry.workflow_id }}", _moolabs_err
    )

{% elif entry.pattern == "cost-only" %}
# ─────────────────────────────────────────────────────────────────────────────
# moolabs cost-only emission via OTel
# TODO (§10 #3): the unified Moolabs SDK does not yet expose a cost-event endpoint.
#                Cost flows via the dual-transport helper today (OTel span attributes
#                preferred, structured log fallback). When the SDK adds its cost-event
#                method (same `Moolabs` client, exact path TBD by platform team),
#                emit_cost_event_safe() swaps its primary branch to that SDK call —
#                no changes needed at this call site.
# Reference: cost-billing-shared/sdk-surface-reference.md §"Direct cost-event emission"
# ─────────────────────────────────────────────────────────────────────────────

from opentelemetry import trace as _moolabs_trace

_moolabs_span = _moolabs_trace.get_current_span()
if _moolabs_span and _moolabs_span.is_recording():
    _moolabs_span.set_attribute("moolabs.workflow_id", "{{ entry.workflow_id }}")
    _moolabs_span.set_attribute("moolabs.cost.kind", "{{ entry.workflow_id.split('.')[-1] }}")
    {% if "request_id" in attribution_keys %}
    _moolabs_span.set_attribute("moolabs.request.id", request.state.request_id)
    {% endif %}
    {% if "customer_id" in attribution_keys %}
    _moolabs_span.set_attribute("moolabs.customer.id", str(customer_id))
    {% endif %}
{% endif %}
