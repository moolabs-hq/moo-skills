{# TypeScript + Express codemod template for /cost-billing-instrument.

   Express-specific attribution-key sources:
     requestId → req.headers['x-request-id']  (must be string-narrowed)
     tenantId  → (req as any).tenantId        (middleware-set; cast for express req types)
     customerId → (req as any).user?.customerId

   Helper API is the camelCase TypeScript shape (emitUsageEventSafe,
   emitCostEventSafe — see typescript-moolabs-client.ts.j2 for definitions).

   Variables expected: identical shape to python-fastapi.j2.
#}
{% if entry.pattern == "sibling-pair" %}
// ─────────────────────────────────────────────────────────────────────────
// moolabs SDK inserts (sibling-pair pattern)
// usage event → emitUsageEventSafe() → client.usage.ingestEvents()
// cost events → emitCostEventSafe() — SDK if Phase 1.5 snapshot says capable,
//               structured-log recovery rail otherwise.
//
// Both call paths go through the per-service helper (moolabs-client.ts).
// NEVER instantiate Moolabs() inline; helper owns fail-open + never-drop.
// ─────────────────────────────────────────────────────────────────────────
import { emitUsageEventSafe, emitCostEventSafe } from '@/services/moolabs-client';

// Cost-event side of the sibling pair.
emitCostEventSafe({
  kind: '{{ entry.cost_kind | default("unknown") }}',
  {% if "tenant_id" in attribution_keys %}tenantId: (req as any).tenantId,
  {% endif %}{% if "consumer_agent" in attribution_keys %}consumerAgent: {{ entry.consumer_agent_source | default("undefined") }},
  {% endif %}{% if entry.cost_micros_source %}costMicros: {{ entry.cost_micros_source }},
  {% endif %}attributes: {
    'workflow_id': '{{ entry.workflow_id }}',
    'event_type': '{{ entry.event_type }}',
    {% for cost_wf in entry.cost_workflow_ids %}'upstream.{{ loop.index }}.workflow_id': '{{ cost_wf }}',
    {% endfor %}{% if "request_id" in attribution_keys %}'request.id': String(req.headers['x-request-id'] ?? ''),
    {% endif %}{% if "customer_id" in attribution_keys %}'customer.id': String((req as any).user?.customerId ?? ''),
    {% endif %}{% if "feature_id" in attribution_keys %}'feature.id': '{{ entry.workflow_id.split(".")[1] }}',
    {% endif %}
  },
});

// Usage event — sibling-pair primary emission.
// REVIEW: idempotency key derivation (confidence={{ entry.idempotency_anchor.confidence }})
await emitUsageEventSafe({
  eventType: '{{ entry.event_type }}',
  subject: String({{ entry.idempotency_anchor.path_param if "customer_id" in attribution_keys else "req.headers['x-request-id'] ?? ''" }}),
  data: {
    quantity: {{ entry.refund_unit.derivation }},
    unit: '{{ entry.refund_unit.unit }}',
  },
  {% if "request_id" in attribution_keys %}correlationId: String(req.headers['x-request-id'] ?? ''),{% endif %}
});
{% elif entry.pattern == "usage-only" %}
// ─────────────────────────────────────────────────────────────────────────
// moolabs SDK insert (usage-only pattern) — single usage event; no
// cost-bearing call at this site. Routes through the per-service helper.
// ─────────────────────────────────────────────────────────────────────────
import { emitUsageEventSafe } from '@/services/moolabs-client';

// REVIEW: idempotency key derivation (confidence={{ entry.idempotency_anchor.confidence }})
await emitUsageEventSafe({
  eventType: '{{ entry.event_type }}',
  subject: String({{ entry.idempotency_anchor.path_param }}),
  data: {
    quantity: {{ entry.refund_unit.derivation }},
    unit: '{{ entry.refund_unit.unit }}',
  },
  {% if "request_id" in attribution_keys %}correlationId: String(req.headers['x-request-id'] ?? ''),{% endif %}
});
{% elif entry.pattern == "cost-only" %}
// ─────────────────────────────────────────────────────────────────────────
// moolabs cost-only emission via emitCostEventSafe (helper-routed).
// Helper picks the primary transport based on the Phase 1.5 SDK snapshot.
// ─────────────────────────────────────────────────────────────────────────
import { emitCostEventSafe } from '@/services/moolabs-client';

emitCostEventSafe({
  kind: '{{ entry.cost_kind | default(entry.workflow_id.split(".")[-1]) }}',
  {% if "tenant_id" in attribution_keys %}tenantId: (req as any).tenantId,
  {% endif %}{% if "consumer_agent" in attribution_keys %}consumerAgent: {{ entry.consumer_agent_source | default("undefined") }},
  {% endif %}{% if entry.cost_micros_source %}costMicros: {{ entry.cost_micros_source }},
  {% endif %}attributes: {
    'workflow_id': '{{ entry.workflow_id }}',
    {% if "request_id" in attribution_keys %}'request.id': String(req.headers['x-request-id'] ?? ''),
    {% endif %}{% if "customer_id" in attribution_keys %}'customer.id': String((req as any).user?.customerId ?? ''),
    {% endif %}
  },
});
{% endif %}
