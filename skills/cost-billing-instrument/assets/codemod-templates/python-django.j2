{# Python + Django codemod template for /cost-billing-instrument.

   Every branch (sibling-pair / usage-only / cost-only) emits ONLY calls into
   the per-service helper (moolabs_client.py — generated by Phase 2). Call
   sites NEVER instantiate Moolabs() inline and NEVER touch SDK namespace
   paths directly. Helper owns fail-open, transport selection, and recovery
   rail.

   Django-specific attribution-key sources:
     request_id → request.META.get("HTTP_X_REQUEST_ID")
     tenant_id  → getattr(request, "tenant_id", None)   # set by middleware
     customer_id → request.user.customer_id when authenticated

   Variables expected: same as python-fastapi.j2 — entry.{pattern, event_type,
   workflow_id, idempotency_anchor, refund_unit, cost_kind, cost_micros_source,
   cost_workflow_ids, consumer_agent_source}, attribution_keys[].
#}
{% if entry.pattern == "sibling-pair" %}
# ─────────────────────────────────────────────────────────────────────────────
# moolabs SDK inserts (sibling-pair pattern)
# usage event → emit_usage_event_safe() → client.usage.ingest_events()
# cost events → emit_cost_event_safe() — SDK if Phase 1.5 snapshot says capable,
#               structured-log recovery rail otherwise.
#
# Both call paths go through the per-service helper (moolabs_client.py).
# NEVER instantiate Moolabs() inline; helper owns fail-open + never-drop.
# ─────────────────────────────────────────────────────────────────────────────
from app.services.moolabs_client import emit_usage_event_safe, emit_cost_event_safe

# Cost-event side of the sibling pair.
emit_cost_event_safe(
    kind="{{ entry.cost_kind | default('unknown') }}",
    {% if "tenant_id" in attribution_keys %}tenant_id=getattr(request, "tenant_id", None),
    {% endif %}{% if "consumer_agent" in attribution_keys %}consumer_agent={{ entry.consumer_agent_source | default("None") }},
    {% endif %}{% if entry.cost_micros_source %}cost_micros={{ entry.cost_micros_source }},
    {% endif %}attributes={
        "workflow_id": "{{ entry.workflow_id }}",
        "event_type": "{{ entry.event_type }}",
        {% for cost_wf in entry.cost_workflow_ids %}"upstream.{{ loop.index }}.workflow_id": "{{ cost_wf }}",
        {% endfor %}{% if "request_id" in attribution_keys %}"request.id": request.META.get("HTTP_X_REQUEST_ID"),
        {% endif %}{% if "customer_id" in attribution_keys %}"customer.id": str(getattr(request.user, "customer_id", "") or ""),
        {% endif %}{% if "feature_id" in attribution_keys %}"feature.id": "{{ entry.workflow_id.split('.')[1] }}",
        {% endif %}
    },
)

# Usage event — sibling-pair primary emission.
# REVIEW: idempotency key derivation (confidence={{ entry.idempotency_anchor.confidence }})
emit_usage_event_safe(
    event_type="{{ entry.event_type }}",
    subject=str({{ entry.idempotency_anchor.path_param if "customer_id" in attribution_keys else "request.META.get('HTTP_X_REQUEST_ID')" }}),
    data={
        "quantity": {{ entry.refund_unit.derivation }},
        "unit": "{{ entry.refund_unit.unit }}",
    },
    {% if "request_id" in attribution_keys %}correlation_id=request.META.get("HTTP_X_REQUEST_ID"),{% endif %}
)
{% elif entry.pattern == "usage-only" %}
# ─────────────────────────────────────────────────────────────────────────────
# moolabs SDK insert (usage-only pattern) — single usage event; no cost-bearing
# call at this site. Routes through the per-service helper.
# ─────────────────────────────────────────────────────────────────────────────
from app.services.moolabs_client import emit_usage_event_safe

# REVIEW: idempotency key derivation (confidence={{ entry.idempotency_anchor.confidence }})
emit_usage_event_safe(
    event_type="{{ entry.event_type }}",
    subject=str({{ entry.idempotency_anchor.path_param }}),
    data={
        "quantity": {{ entry.refund_unit.derivation }},
        "unit": "{{ entry.refund_unit.unit }}",
    },
    {% if "request_id" in attribution_keys %}correlation_id=request.META.get("HTTP_X_REQUEST_ID"),{% endif %}
)
{% elif entry.pattern == "cost-only" %}
# ─────────────────────────────────────────────────────────────────────────────
# moolabs cost-only emission via emit_cost_event_safe (helper-routed).
# Helper picks the primary transport based on the Phase 1.5 SDK snapshot.
# ─────────────────────────────────────────────────────────────────────────────
from app.services.moolabs_client import emit_cost_event_safe

emit_cost_event_safe(
    kind="{{ entry.cost_kind | default(entry.workflow_id.split('.')[-1]) }}",
    {% if "tenant_id" in attribution_keys %}tenant_id=getattr(request, "tenant_id", None),
    {% endif %}{% if "consumer_agent" in attribution_keys %}consumer_agent={{ entry.consumer_agent_source | default("None") }},
    {% endif %}{% if entry.cost_micros_source %}cost_micros={{ entry.cost_micros_source }},
    {% endif %}attributes={
        "workflow_id": "{{ entry.workflow_id }}",
        {% if "request_id" in attribution_keys %}"request.id": request.META.get("HTTP_X_REQUEST_ID"),
        {% endif %}{% if "customer_id" in attribution_keys %}"customer.id": str(getattr(request.user, "customer_id", "") or ""),
        {% endif %}
    },
)
{% endif %}
