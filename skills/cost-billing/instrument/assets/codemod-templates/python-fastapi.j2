{# Python + FastAPI codemod template for /cost-billing-instrument.

   Targets SDK v0.3.0-rc1 unified-ingest ergonomic helpers:
     sibling-pair  -> emit_event_safe(...)          (dual-lane, one call)
     usage-only    -> emit_usage_event_safe(...)
     cost-only     -> emit_cost_event_safe(...)

   Call sites NEVER instantiate Moolabs() inline and NEVER touch SDK namespace
   paths directly. Helper owns the env-gated never-drop rail (SDK_DEVELOPMENT
   non-empty -> raise; unset -> structured-log fallback). tenant_id is absent
   on the wire (the server derives the tenant from the API key).

   Variables expected:
     entry.pattern               — sibling-pair | usage-only | cost-only
     entry.event_type            — e.g. "completion.delivered"
     entry.workflow_id           — stable per-feature identifier (used as meter_slug)
     entry.idempotency_anchor    — { handler, path_param, confidence }
     entry.refund_unit           — { unit, derivation } (derivation is the usage scalar)
     entry.cost_kind             — e.g. "llm-tokens" (cost lane span kind)
     entry.cost_micros_source    — e.g. "response.cost_micros"
     attribution_sources         — { request_id, customer_id, consumer_agent }
                                    Each is a CONFIRMED Python expression (Phase 1.6 binding)
                                    or None (skip / use fallback).
     entry.attribution_imports   — import statements the binding expressions need
                                    (e.g. get_correlation_id); emitted so the
                                    insert doesn't NameError. May be empty.
#}
{%- macro guarded(g) -%}
{% if g %}if {{ g }}:
{{ caller() | trim | indent(4, first=True) }}
{% else %}{{ caller() | trim }}
{% endif %}
{%- endmacro -%}
{% for _moolabs_imp in entry.attribution_imports %}{{ _moolabs_imp }}
{% endfor %}{% if entry.pattern == "sibling-pair" %}
# ─────────────────────────────────────────────────────────────────────────────
# moolabs SDK insert (sibling-pair, v0.3.0-rc1). Both lanes in ONE call via
# emit_event_safe -> client.events.ingest(...). entity_id is the cross-lane
# join key (preserves request_id for join downstream). Attribution sources
# bound in Phase 1.6 (attribution-bindings.yaml).
# ─────────────────────────────────────────────────────────────────────────────
from {{ entry.helper_import_path }} import emit_event_safe
{% if entry.event_type_const or entry.meter_slug_const or entry.feature_key_const or entry.span_type_const %}from {{ entry.slugs_import_path }} import (
{% if entry.event_type_const %}    {{ entry.event_type_const }},
{% endif %}{% if entry.meter_slug_const %}    {{ entry.meter_slug_const }},
{% endif %}{% if entry.feature_key_const %}    {{ entry.feature_key_const }},
{% endif %}{% if entry.span_type_const %}    {{ entry.span_type_const }},
{% endif %})
{% endif %}import uuid as _moolabs_uuid

_moolabs_span_id = str(_moolabs_uuid.uuid4())
{% if not attribution_sources.request_id %}_moolabs_event_id = str(_moolabs_uuid.uuid4())
{% endif %}
{% if entry.idempotency_anchor is defined and entry.idempotency_anchor %}# REVIEW: idempotency anchor (confidence={{ entry.idempotency_anchor.confidence }}){% else %}# REVIEW idempotency: confirm entity_id is STABLE across a retry of this
# event — a per-request / correlation id double-counts on retry.{% endif %}
{% if not attribution_sources.entity_id %}# >>> ADD THE ENTITY_ID <<< — entity_id UNBOUND; emitting a placeholder so the
# cost is captured, not dropped. Replace "__MOOLABS_ADD_ENTITY_ID__" with the
# metered entity id and re-run (never bill on the correlation id — double-counts).
{% endif %}{% call guarded(entry.emission_guard) -%}
emit_event_safe(
    event_type={{ entry.event_type_const if entry.event_type_const else '"' ~ (entry.event_type if entry.event_type else entry.workflow_id) ~ '"' }},
    customer_id=str({{ attribution_sources.customer_id if attribution_sources.customer_id else (attribution_sources.request_id if attribution_sources.request_id else '"unknown"') }}),
    entity_id={{ ('str(' ~ attribution_sources.entity_id ~ ')') if attribution_sources.entity_id else '"__MOOLABS_ADD_ENTITY_ID__"' }},
    # ── Usage lane ──
    meter_slug={{ entry.meter_slug_const if entry.meter_slug_const else '"' ~ entry.workflow_id ~ '"' }},
    value={{ entry.refund_unit.derivation }},
    # ── Cost lane ──
    spans=[{
        "span_id": _moolabs_span_id,
        {% if entry.cost_micros_source %}"cost_micros": {{ entry.cost_micros_source }},
        {% endif %}{% if entry.cost_kind %}"kind": {{ entry.span_type_const if entry.span_type_const else '"' ~ entry.cost_kind ~ '"' }},
        {% endif %}
    }],
    # ── Open-shape attribution (lands at data.meta.<key>) ──
    meta={
        {% if not attribution_sources.entity_id %}"entity_id_status": "UNATTRIBUTED_PLACEHOLDER",
        {% endif %}"workflow_id": "{{ entry.workflow_id }}",
        "feature_key": {{ entry.feature_key_const if entry.feature_key_const else '"' ~ (entry.workflow_id.split('.')[1] if entry.workflow_id.count('.') >= 1 else entry.workflow_id) ~ '"' }},
        {% if attribution_sources.consumer_agent %}"consumer_agent": {{ attribution_sources.consumer_agent }},
        {% endif %}{% if attribution_sources.request_id %}"correlation_id": {{ attribution_sources.request_id }},
        {% endif %}
    },
)
{%- endcall %}
