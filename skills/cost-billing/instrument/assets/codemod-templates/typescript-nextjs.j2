{# TypeScript + Next.js (App Router) codemod template for /cost-billing-instrument.

   Attribution sources come from attribution-bindings.yaml (Phase 1.6).
   For Server Actions / Server Components, the developer may have a different
   source (e.g. `headers().get('x-request-id')` from `next/headers`) — Phase 1.6
   captures that per-file via overrides[].

   PREREQ: callsite is in a route handler with `request: NextRequest` in scope
   OR the binding's source expression resolves cleanly in the file's context.

   Variables: same shape as python-fastapi.j2.
#}
{% if entry.pattern == "sibling-pair" %}
// ─────────────────────────────────────────────────────────────────────────
// moolabs SDK inserts (sibling-pair pattern). Helper-routed.
// Attribution sources confirmed in Phase 1.6.
// PREREQ: source expressions resolve in scope at this insert site.
// ─────────────────────────────────────────────────────────────────────────
import { emitUsageEventSafe, emitCostEventSafe } from '@/services/moolabs-client';

emitCostEventSafe({
  // Event-specific
  kind: '{{ entry.cost_kind | default("unknown") }}',
  {% if entry.cost_micros_source %}costMicros: {{ entry.cost_micros_source }},
  {% endif %}attributes: {
    'workflow_id': '{{ entry.workflow_id }}',
    'event_type': '{{ entry.event_type }}',
    {% for cost_wf in entry.cost_workflow_ids %}'upstream.{{ loop.index }}.workflow_id': '{{ cost_wf }}',
    {% endfor %}
  },
  // Shared envelope
  {% if attribution_sources.request_id %}requestId: String({{ attribution_sources.request_id }} ?? ''),
  {% endif %}{% if attribution_sources.customer_id %}customerId: String({{ attribution_sources.customer_id }} ?? ''),
  {% endif %}{% if attribution_sources.consumer_agent %}consumerAgent: {{ attribution_sources.consumer_agent }},
  {% endif %}
});

// REVIEW: idempotency key derivation (confidence={{ entry.idempotency_anchor.confidence }})
await emitUsageEventSafe({
  // Event-specific
  eventType: '{{ entry.event_type }}',
  subject: String({{ attribution_sources.customer_id if attribution_sources.customer_id else (attribution_sources.request_id if attribution_sources.request_id else "'unknown'") }} ?? ''),
  quantity: {{ entry.refund_unit.derivation }},
  unit: '{{ entry.refund_unit.unit }}',
  // Shared envelope
  {% if attribution_sources.request_id %}requestId: String({{ attribution_sources.request_id }} ?? ''),
  {% endif %}{% if attribution_sources.customer_id %}customerId: String({{ attribution_sources.customer_id }} ?? ''),
  {% endif %}{% if attribution_sources.consumer_agent %}consumerAgent: {{ attribution_sources.consumer_agent }},
  {% endif %}{% if attribution_sources.request_id %}correlationId: String({{ attribution_sources.request_id }} ?? ''),
  {% endif %}
});
{% elif entry.pattern == "usage-only" %}
// ─────────────────────────────────────────────────────────────────────────
// moolabs SDK insert (usage-only pattern). Helper-routed.
// PREREQ: source expressions resolve in scope at this insert site.
// ─────────────────────────────────────────────────────────────────────────
import { emitUsageEventSafe } from '@/services/moolabs-client';

// REVIEW: idempotency key derivation (confidence={{ entry.idempotency_anchor.confidence }})
await emitUsageEventSafe({
  // Event-specific
  eventType: '{{ entry.event_type }}',
  subject: String({{ attribution_sources.customer_id if attribution_sources.customer_id else (attribution_sources.request_id if attribution_sources.request_id else "'unknown'") }} ?? ''),
  quantity: {{ entry.refund_unit.derivation }},
  unit: '{{ entry.refund_unit.unit }}',
  // Shared envelope
  {% if attribution_sources.request_id %}requestId: String({{ attribution_sources.request_id }} ?? ''),
  {% endif %}{% if attribution_sources.customer_id %}customerId: String({{ attribution_sources.customer_id }} ?? ''),
  {% endif %}{% if attribution_sources.consumer_agent %}consumerAgent: {{ attribution_sources.consumer_agent }},
  {% endif %}{% if attribution_sources.request_id %}correlationId: String({{ attribution_sources.request_id }} ?? ''),
  {% endif %}
});
{% elif entry.pattern == "cost-only" %}
// ─────────────────────────────────────────────────────────────────────────
// moolabs cost-only emission (helper-routed). Attribution sources from Phase 1.6.
// ─────────────────────────────────────────────────────────────────────────
import { emitCostEventSafe } from '@/services/moolabs-client';

emitCostEventSafe({
  // Event-specific
  kind: '{{ entry.cost_kind | default(entry.workflow_id.split(".")[-1]) }}',
  {% if entry.cost_micros_source %}costMicros: {{ entry.cost_micros_source }},
  {% endif %}attributes: {
    'workflow_id': '{{ entry.workflow_id }}',
  },
  // Shared envelope
  {% if attribution_sources.request_id %}requestId: String({{ attribution_sources.request_id }} ?? ''),
  {% endif %}{% if attribution_sources.customer_id %}customerId: String({{ attribution_sources.customer_id }} ?? ''),
  {% endif %}{% if attribution_sources.consumer_agent %}consumerAgent: {{ attribution_sources.consumer_agent }},
  {% endif %}
});
{% endif %}
