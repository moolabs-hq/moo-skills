{# TypeScript moolabs-client.ts — per-service helper, generated ONCE per service by /cost-billing-instrument.

   Targets SDK v0.3.0-rc1 unified-ingest ergonomic methods. Every per-callsite
   emission MUST go through emitUsageEventSafe / emitCostEventSafe /
   emitEventSafe — NEVER instantiate Moolabs(...) inline.

   Variables expected:
     service_slug, signoff_chain_hashes, sdk_key_location.*, sdk_key_read_pattern,
     sdk_pinned_version, telemetry.mode
#}
/**
 * Moolabs SDK client — module-level singleton for {{ service_slug }} billing emissions.
 *
 * Wired by /cost-billing-instrument codemod on {{ generated_at }} per the signed gates:
{% for h in signoff_chain_hashes %} *   - {{ h.stage }}: {{ h.file }} (sha {{ h.sha256[:8] }})
{% endfor %} *
 * SDK version: {{ sdk_pinned_version | default("v0.3.0-rc1") }}  (unified-ingest ergonomic methods)
 *
 * Three emission helpers mapping 1:1 to the v0.3.0 SDK methods:
 *   emitUsageEventSafe(args) -> client.usage.ingestEvent(args)
 *   emitCostEventSafe(args)  -> client.cost.ingestEvent(args)
 *   emitEventSafe(args)      -> client.events.ingest(args)   // sibling-pair, dual-lane
 *
 * tenantId is intentionally absent from every helper signature — the server
 * derives tenant identity from the API key (FR-3 in the SDK unified-ingest PRD).
 * entityId is the threading key for sibling-pair join downstream.
 *
 * Error handling is env-gated (single decision point in handleEmitErr):
 *   SDK_DEVELOPMENT non-empty -> throw on any SDK error (validation or transport)
 *                                so the developer sees the failure at the call site.
 *   SDK_DEVELOPMENT unset     -> structured-log recovery rail; the emission is
 *                                never silently dropped. Default for prod.
 *
 * THIS IS THE ONLY MODULE THAT INSTANTIATES THE MOOLABS CLIENT.
 */

import {
  Moolabs,
  type UsageIngestEventArgs,
  type CostIngestEventArgs,
  type EventsIngestArgs,
} from 'moolabs';
{% if sdk_key_location.strategy == "aws_secrets_manager" %}import { SecretsManagerClient, GetSecretValueCommand } from '@aws-sdk/client-secrets-manager';
{% elif sdk_key_location.strategy == "gcp_secret_manager" %}import { SecretManagerServiceClient } from '@google-cloud/secret-manager';
{% elif sdk_key_location.strategy == "vault" %}import vault from 'node-vault';
{% endif %}
import { logger } from './logger'; // adapt to {{ service_slug }}'s existing logger import

// Env-gated strict/lax mode — same var name as the Python and Go helpers for
// cross-language parity. Non-empty -> throw (dev mode); unset -> log-rail
// swallow (prod).
const DEV_ENV_VAR = 'SDK_DEVELOPMENT';

{% if telemetry.mode == "brownfield" %}
// Brownfield directive: {{ service_slug }} already has a live TracerProvider.
// Do NOT register a second provider.
{% endif %}

let _cachedApiKey: string | null = null;
let _cachedClient: Moolabs | null = null;

async function resolveApiKey(): Promise<string> {
  if (_cachedApiKey !== null) return _cachedApiKey;
  const env = process.env.APP_ENV ?? 'prod';
{% if sdk_key_location.strategy == "aws_secrets_manager" %}
  const secretId = `{{ sdk_key_location.secret_id_template }}`.replace('{env}', env);
  try {
    const sm = new SecretsManagerClient({ region: '{{ sdk_key_location.region | default("us-east-1") }}' });
    const resp = await sm.send(new GetSecretValueCommand({ SecretId: secretId }));
    _cachedApiKey = resp.SecretString ?? '';
    return _cachedApiKey;
  } catch (exc) {
    logger.error({ secretId, error: String(exc), policy: 'fail_open_silent_swallow' },
                 'moolabs.sdk_key.resolution_failed');
    _cachedApiKey = '';
    return '';
  }
{% elif sdk_key_location.strategy == "gcp_secret_manager" %}
  const secretId = `{{ sdk_key_location.secret_id_template }}`.replace('{env}', env);
  try {
    const sm = new SecretManagerServiceClient();
    const [resp] = await sm.accessSecretVersion({ name: secretId });
    _cachedApiKey = resp.payload?.data?.toString('utf-8') ?? '';
    return _cachedApiKey;
  } catch (exc) {
    logger.error({ secretId, error: String(exc), policy: 'fail_open_silent_swallow' },
                 'moolabs.sdk_key.resolution_failed');
    _cachedApiKey = '';
    return '';
  }
{% elif sdk_key_location.strategy == "vault" %}
  const secretPath = `{{ sdk_key_location.secret_id_template }}`.replace('{env}', env);
  try {
    const v = vault({});
    const resp = await v.read(`secret/data/${secretPath}`);
    _cachedApiKey = resp?.data?.data?.api_key ?? '';
    return _cachedApiKey;
  } catch (exc) {
    logger.error({ secretPath, error: String(exc), policy: 'fail_open_silent_swallow' },
                 'moolabs.sdk_key.resolution_failed');
    _cachedApiKey = '';
    return '';
  }
{% elif sdk_key_location.strategy == "env_var" %}
  _cachedApiKey = process.env.MOOLABS_API_KEY ?? '';
  return _cachedApiKey;
{% elif sdk_key_location.strategy == "custom" %}
  try {
    {{ sdk_key_read_pattern | indent(4) }}
  } catch (exc) {
    logger.error({ error: String(exc), policy: 'fail_open_silent_swallow' },
                 'moolabs.sdk_key.resolution_failed');
    _cachedApiKey = '';
    return '';
  }
{% endif %}
}

async function getClient(): Promise<Moolabs> {
  if (_cachedClient !== null) return _cachedClient;
  _cachedClient = new Moolabs({ apiKey: await resolveApiKey() });
  return _cachedClient;
}

// Single env-gated decision point. Strict (SDK_DEVELOPMENT non-empty) -> throw
// so the developer fixes the call site. Lax (default / prod) -> structured-log
// recovery rail; never silently drop.
function handleEmitErr(eventClass: string, fields: Record<string, unknown>, err: unknown): void {
  const errMsg = err instanceof Error ? err.message : String(err);
  if (process.env[DEV_ENV_VAR]) {
    throw new Error(
      `moolabsclient: ${eventClass} emission failed (SDK_DEVELOPMENT mode — unset to swallow): ${errMsg}`,
    );
  }
  logger.warn({ ...fields, error: errMsg }, `moolabs.${eventClass}.event`);
}

// ── emit helpers (v0.3.0-rc1 ergonomic methods) ─────────────────────────────

export async function emitUsageEventSafe(args: UsageIngestEventArgs): Promise<void> {
  const fullArgs: UsageIngestEventArgs = { ...args, source: args.source ?? '{{ service_slug }}' };
  try {
    const client = await getClient();
    await client.usage.ingestEvent(fullArgs);
  } catch (err) {
    handleEmitErr('usage', usageFallback(fullArgs), err);
  }
}

export async function emitCostEventSafe(args: CostIngestEventArgs): Promise<void> {
  const fullArgs: CostIngestEventArgs = { ...args, source: args.source ?? '{{ service_slug }}' };
  try {
    const client = await getClient();
    await client.cost.ingestEvent(fullArgs);
  } catch (err) {
    handleEmitErr('cost', costFallback(fullArgs), err);
  }
}

export async function emitEventSafe(args: EventsIngestArgs): Promise<void> {
  const fullArgs: EventsIngestArgs = { ...args, source: args.source ?? '{{ service_slug }}' };
  try {
    const client = await getClient();
    await client.events.ingest(fullArgs);
  } catch (err) {
    handleEmitErr('event', eventFallback(fullArgs), err);
  }
}

// ── fallback field builders ────────────────────────────────────────────────

function usageFallback(a: UsageIngestEventArgs): Record<string, unknown> {
  return {
    transport: 'log_recovery_rail',
    policy: 'never_drop_usage_event',
    eventType: a.eventType,
    customerId: a.customerId,
    entityId: a.entityId,
    meterSlug: a.meterSlug,
    value: a.value,
    source: a.source,
    ...(a.provider !== undefined && { provider: a.provider }),
    ...(a.model !== undefined && { model: a.model }),
    ...(a.totalTokens !== undefined && { totalTokens: a.totalTokens }),
    ...(a.latencyMs !== undefined && { latencyMs: a.latencyMs }),
    ...(a.status !== undefined && { status: a.status }),
    ...(a.eventId !== undefined && { eventId: a.eventId }),
  };
}

function costFallback(a: CostIngestEventArgs): Record<string, unknown> {
  return {
    transport: 'log_recovery_rail',
    policy: 'never_drop_cost_event',
    eventType: a.eventType,
    customerId: a.customerId,
    entityId: a.entityId,
    spanCount: a.spans.length,
    source: a.source,
    ...(a.provider !== undefined && { provider: a.provider }),
    ...(a.model !== undefined && { model: a.model }),
    ...(a.totalTokens !== undefined && { totalTokens: a.totalTokens }),
    ...(a.latencyMs !== undefined && { latencyMs: a.latencyMs }),
    ...(a.status !== undefined && { status: a.status }),
    ...(a.eventId !== undefined && { eventId: a.eventId }),
  };
}

function eventFallback(a: EventsIngestArgs): Record<string, unknown> {
  return {
    transport: 'log_recovery_rail',
    policy: 'never_drop_event',
    eventType: a.eventType,
    customerId: a.customerId,
    entityId: a.entityId,
    source: a.source,
    ...(a.meterSlug !== undefined && { meterSlug: a.meterSlug }),
    ...(a.value !== undefined && { value: a.value }),
    ...(a.spans !== undefined && { spanCount: a.spans.length }),
    ...(a.eventId !== undefined && { eventId: a.eventId }),
  };
}
