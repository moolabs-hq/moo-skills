{# TypeScript + NestJS codemod template for /cost-billing-instrument.

   Targets SDK v0.3.0-rc1 unified-ingest ergonomic helpers (same shape as
   typescript-express.j2). Attribution sources come from attribution-bindings.yaml
   (Phase 1.6). The developer's NestJS middleware/interceptor sets these on
   `request` or a request-scoped provider; the template substitutes those
   verbatim — never guesses attribute names.

   Variables: same shape as python-fastapi.j2 (incl. entry.attribution_imports —
   each binding's requires_import, in TS import syntax; emitted verbatim).
#}
{% for _moolabs_imp in entry.attribution_imports %}{{ _moolabs_imp }}
{% endfor %}{% if entry.pattern == "sibling-pair" %}
// ─────────────────────────────────────────────────────────────────────────
// moolabs SDK insert (sibling-pair, v0.3.0-rc1). Both lanes in ONE call via
// emitEventSafe -> client.events.ingest(...).
// ─────────────────────────────────────────────────────────────────────────
import { emitEventSafe } from '{{ entry.helper_import_path }}';
{% if entry.event_type_const or entry.meter_slug_const or entry.feature_key_const or entry.span_type_const %}import {
{% if entry.event_type_const %}  {{ entry.event_type_const }},
{% endif %}{% if entry.meter_slug_const %}  {{ entry.meter_slug_const }},
{% endif %}{% if entry.feature_key_const %}  {{ entry.feature_key_const }},
{% endif %}{% if entry.span_type_const %}  {{ entry.span_type_const }},
{% endif %}} from '{{ entry.slugs_import_path }}';
{% endif %}
const _moolabsSpanId = typeof crypto !== 'undefined' && 'randomUUID' in crypto ? crypto.randomUUID().replace(/-/g, '') : Math.random().toString(36).slice(2);
{% if not attribution_sources.request_id %}const _moolabsEventId = typeof crypto !== 'undefined' && 'randomUUID' in crypto ? crypto.randomUUID().replace(/-/g, '') : Math.random().toString(36).slice(2);
{% endif %}
{% if entry.idempotency_anchor is defined and entry.idempotency_anchor %}// REVIEW: idempotency anchor (confidence={{ entry.idempotency_anchor.confidence }}){% else %}// REVIEW idempotency: confirm entity_id is STABLE across a retry of this
// event — a per-request / correlation id double-counts on retry.{% endif %}
await emitEventSafe({
  eventType: {{ entry.event_type_const if entry.event_type_const else "'" ~ (entry.event_type if entry.event_type else entry.workflow_id) ~ "'" }},
  customerId: String({{ attribution_sources.customer_id if attribution_sources.customer_id else (attribution_sources.request_id if attribution_sources.request_id else "'unknown'") }} ?? ''),
  entityId: String({{ attribution_sources.request_id if attribution_sources.request_id else "_moolabsEventId" }} ?? ''),
  meterSlug: {{ entry.meter_slug_const if entry.meter_slug_const else "'" ~ entry.workflow_id ~ "'" }},
  value: {{ entry.refund_unit.derivation }},
  spans: [{
    spanId: _moolabsSpanId,
    {% if entry.cost_micros_source %}costMicros: {{ entry.cost_micros_source }},
    {% endif %}{% if entry.cost_kind %}kind: {{ entry.span_type_const if entry.span_type_const else "'" ~ entry.cost_kind ~ "'" }},
    {% endif %}
  }],
  meta: {
    workflow_id: '{{ entry.workflow_id }}',
    feature_key: {{ entry.feature_key_const if entry.feature_key_const else "'" ~ (entry.workflow_id.split(".")[1] if entry.workflow_id.count(".") >= 1 else entry.workflow_id) ~ "'" }},
    {% if attribution_sources.consumer_agent %}consumer_agent: {{ attribution_sources.consumer_agent }},
    {% endif %}{% if attribution_sources.request_id %}correlation_id: String({{ attribution_sources.request_id }} ?? ''),
    {% endif %}
  },
});
{% elif entry.pattern == "usage-only" %}
// ─────────────────────────────────────────────────────────────────────────
// moolabs SDK insert (usage-only, v0.3.0-rc1) — emitUsageEventSafe.
// ─────────────────────────────────────────────────────────────────────────
import { emitUsageEventSafe } from '{{ entry.helper_import_path }}';
{% if entry.event_type_const or entry.meter_slug_const or entry.feature_key_const %}import {
{% if entry.event_type_const %}  {{ entry.event_type_const }},
{% endif %}{% if entry.meter_slug_const %}  {{ entry.meter_slug_const }},
{% endif %}{% if entry.feature_key_const %}  {{ entry.feature_key_const }},
{% endif %}} from '{{ entry.slugs_import_path }}';
{% endif %}{% if not attribution_sources.request_id %}
const _moolabsEventId = typeof crypto !== 'undefined' && 'randomUUID' in crypto ? crypto.randomUUID().replace(/-/g, '') : Math.random().toString(36).slice(2);
{% endif %}
{% if entry.idempotency_anchor is defined and entry.idempotency_anchor %}// REVIEW: idempotency anchor (confidence={{ entry.idempotency_anchor.confidence }}){% else %}// REVIEW idempotency: confirm entity_id is STABLE across a retry of this
// event — a per-request / correlation id double-counts on retry.{% endif %}
await emitUsageEventSafe({
  eventType: {{ entry.event_type_const if entry.event_type_const else "'" ~ (entry.event_type if entry.event_type else entry.workflow_id) ~ "'" }},
  customerId: String({{ attribution_sources.customer_id if attribution_sources.customer_id else (attribution_sources.request_id if attribution_sources.request_id else "'unknown'") }} ?? ''),
  entityId: String({{ attribution_sources.request_id if attribution_sources.request_id else "_moolabsEventId" }} ?? ''),
  meterSlug: {{ entry.meter_slug_const if entry.meter_slug_const else "'" ~ entry.workflow_id ~ "'" }},
  value: {{ entry.refund_unit.derivation }},
  meta: {
    workflow_id: '{{ entry.workflow_id }}',
    feature_key: {{ entry.feature_key_const if entry.feature_key_const else "'" ~ (entry.workflow_id.split(".")[1] if entry.workflow_id.count(".") >= 1 else entry.workflow_id) ~ "'" }},
    {% if attribution_sources.consumer_agent %}consumer_agent: {{ attribution_sources.consumer_agent }},
    {% endif %}{% if attribution_sources.request_id %}correlation_id: String({{ attribution_sources.request_id }} ?? ''),
    {% endif %}
  },
});
{% elif entry.pattern == "cost-only" %}
// ─────────────────────────────────────────────────────────────────────────
// moolabs SDK insert (cost-only, v0.3.0-rc1) — emitCostEventSafe.
// ─────────────────────────────────────────────────────────────────────────
import { emitCostEventSafe } from '{{ entry.helper_import_path }}';
{% if entry.event_type_const or entry.feature_key_const or entry.span_type_const %}import {
{% if entry.event_type_const %}  {{ entry.event_type_const }},
{% endif %}{% if entry.feature_key_const %}  {{ entry.feature_key_const }},
{% endif %}{% if entry.span_type_const %}  {{ entry.span_type_const }},
{% endif %}} from '{{ entry.slugs_import_path }}';
{% endif %}
const _moolabsSpanId = typeof crypto !== 'undefined' && 'randomUUID' in crypto ? crypto.randomUUID().replace(/-/g, '') : Math.random().toString(36).slice(2);
{% if not attribution_sources.request_id %}const _moolabsEventId = typeof crypto !== 'undefined' && 'randomUUID' in crypto ? crypto.randomUUID().replace(/-/g, '') : Math.random().toString(36).slice(2);
{% endif %}
await emitCostEventSafe({
