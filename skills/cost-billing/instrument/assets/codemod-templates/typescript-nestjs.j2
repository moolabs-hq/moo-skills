  customerId: String({{ attribution_sources.customer_id if attribution_sources.customer_id else (attribution_sources.request_id if attribution_sources.request_id else "'unknown'") }} ?? ''),
  entityId: String({{ attribution_sources.request_id if attribution_sources.request_id else "_moolabsEventId" }} ?? ''),
  spans: [{
    spanId: _moolabsSpanId,
    {% if entry.cost_micros_source %}costMicros: {{ entry.cost_micros_source }},
    {% endif %}{% if entry.cost_kind %}kind: {{ entry.span_type_const if entry.span_type_const else "'" ~ entry.cost_kind ~ "'" }},
    {% endif %}
  }],
  meta: {
    workflow_id: '{{ entry.workflow_id }}',
    feature_key: {{ entry.feature_key_const if entry.feature_key_const else "'" ~ (entry.workflow_id.split(".")[1] if entry.workflow_id.count(".") >= 1 else entry.workflow_id) ~ "'" }},
    {% if attribution_sources.consumer_agent %}consumer_agent: {{ attribution_sources.consumer_agent }},
    {% endif %}{% if attribution_sources.request_id %}correlation_id: String({{ attribution_sources.request_id }} ?? ''),
    {% endif %}
  },
});
{% endif %}
