{# Python + Flask codemod template for /cost-billing-instrument.

   Attribution sources come from attribution-bindings.yaml (Phase 1.6).
   Templates substitute the bound expressions verbatim — they do NOT hardcode
   `flask.g.request_id` etc. The developer might keep these in a custom
   `flask.current_app.config['REQUEST_CONTEXT']` or elsewhere.

   Variables: same as python-fastapi.j2.
#}
{% if entry.pattern == "sibling-pair" %}
# ─────────────────────────────────────────────────────────────────────────────
# moolabs SDK inserts (sibling-pair pattern). Helper-routed.
# Attribution sources confirmed in Phase 1.6.
# ─────────────────────────────────────────────────────────────────────────────
from app.services.moolabs_client import emit_usage_event_safe, emit_cost_event_safe
import uuid as _moolabs_uuid

# Shared id for sibling-pair linking — cost event's usage_event_id references this
_moolabs_event_id = str(_moolabs_uuid.uuid4())

emit_cost_event_safe(
    kind="{{ entry.cost_kind | default('unknown') }}",
    {% if attribution_sources.consumer_agent %}consumer_agent={{ attribution_sources.consumer_agent }},
    {% endif %}{% if entry.cost_micros_source %}cost_micros={{ entry.cost_micros_source }},
    {% endif %}attributes={
        "workflow_id": "{{ entry.workflow_id }}",
        "event_type": "{{ entry.event_type }}",
        {% for cost_wf in entry.cost_workflow_ids %}"upstream.{{ loop.index }}.workflow_id": "{{ cost_wf }}",
        {% endfor %}{% if attribution_sources.request_id %}"request.id": {{ attribution_sources.request_id }},
        {% endif %}{% if attribution_sources.customer_id %}"customer.id": str({{ attribution_sources.customer_id }}),
        {% endif %}
    },
)

# REVIEW: idempotency key derivation (confidence={{ entry.idempotency_anchor.confidence }})
emit_usage_event_safe(
    # ── Event-specific ──
    event_type="{{ entry.event_type }}",
    subject=str({{ attribution_sources.customer_id if attribution_sources.customer_id else (attribution_sources.request_id if attribution_sources.request_id else '"unknown"') }}),
    quantity={{ entry.refund_unit.derivation }},
    unit="{{ entry.refund_unit.unit }}",
    # ── Shared envelope ──
    {% if attribution_sources.tenant_id %}tenant_id={{ attribution_sources.tenant_id }},
    {% endif %}feature_key="{{ entry.workflow_id.split('.')[1] if entry.workflow_id.count('.') >= 2 else entry.workflow_id }}",
    {% if attribution_sources.request_id %}request_id={{ attribution_sources.request_id }},
    {% endif %}{% if attribution_sources.customer_id %}customer_id={{ attribution_sources.customer_id }},
    {% endif %}{% if attribution_sources.consumer_agent %}consumer_agent={{ attribution_sources.consumer_agent }},
    {% endif %}{% if attribution_sources.request_id %}correlation_id={{ attribution_sources.request_id }},
    {% endif %}
)
{% elif entry.pattern == "usage-only" %}
# ─────────────────────────────────────────────────────────────────────────────
# moolabs SDK insert (usage-only pattern). Helper-routed.
# Attribution sources confirmed in Phase 1.6.
# ─────────────────────────────────────────────────────────────────────────────
from app.services.moolabs_client import emit_usage_event_safe

# REVIEW: idempotency key derivation (confidence={{ entry.idempotency_anchor.confidence }})
emit_usage_event_safe(
    # ── Event-specific ──
    event_type="{{ entry.event_type }}",
    subject=str({{ attribution_sources.customer_id if attribution_sources.customer_id else (attribution_sources.request_id if attribution_sources.request_id else '"unknown"') }}),
    quantity={{ entry.refund_unit.derivation }},
    unit="{{ entry.refund_unit.unit }}",
    # ── Shared envelope ──
    {% if attribution_sources.tenant_id %}tenant_id={{ attribution_sources.tenant_id }},
    {% endif %}feature_key="{{ entry.workflow_id.split('.')[1] if entry.workflow_id.count('.') >= 2 else entry.workflow_id }}",
    {% if attribution_sources.request_id %}request_id={{ attribution_sources.request_id }},
    {% endif %}{% if attribution_sources.customer_id %}customer_id={{ attribution_sources.customer_id }},
    {% endif %}{% if attribution_sources.consumer_agent %}consumer_agent={{ attribution_sources.consumer_agent }},
    {% endif %}{% if attribution_sources.request_id %}correlation_id={{ attribution_sources.request_id }},
    {% endif %}
)
{% elif entry.pattern == "cost-only" %}
# ─────────────────────────────────────────────────────────────────────────────
# moolabs cost-only emission (helper-routed). Attribution sources from Phase 1.6.
# ─────────────────────────────────────────────────────────────────────────────
from app.services.moolabs_client import emit_cost_event_safe

emit_cost_event_safe(
    # ── Event-specific ──
    kind="{{ entry.cost_kind | default(entry.workflow_id.split('.')[-1]) }}",
    {% if entry.cost_micros_source %}cost_micros={{ entry.cost_micros_source }},
    {% endif %}attributes={
        "workflow_id": "{{ entry.workflow_id }}",
    },
    # ── Shared envelope ──
    {% if attribution_sources.tenant_id %}tenant_id={{ attribution_sources.tenant_id }},
    {% endif %}feature_key="{{ entry.workflow_id.split('.')[1] if entry.workflow_id.count('.') >= 2 else entry.workflow_id }}",
    {% if attribution_sources.request_id %}request_id={{ attribution_sources.request_id }},
    {% endif %}{% if attribution_sources.customer_id %}customer_id={{ attribution_sources.customer_id }},
    {% endif %}{% if attribution_sources.consumer_agent %}consumer_agent={{ attribution_sources.consumer_agent }},
    {% endif %}
)
{% endif %}
