{# Python + Flask codemod template for /cost-billing-instrument.

   Targets SDK v0.3.0-rc1 unified-ingest ergonomic helpers (same shape as
   python-fastapi.j2). Attribution sources come from attribution-bindings.yaml
   (Phase 1.6). Templates substitute the bound expressions verbatim — they do
   NOT hardcode `flask.g.request_id` etc. The developer may keep these in a
   custom `flask.current_app.config['REQUEST_CONTEXT']` or elsewhere.

   Variables: identical to python-fastapi.j2.
#}
{% if entry.pattern == "sibling-pair" %}
# ─────────────────────────────────────────────────────────────────────────────
# moolabs SDK insert (sibling-pair, v0.3.0-rc1). Both lanes in ONE call via
# emit_event_safe -> client.events.ingest(...).
# ─────────────────────────────────────────────────────────────────────────────
from app.services.moolabs_client import emit_event_safe
import uuid as _moolabs_uuid

_moolabs_span_id = str(_moolabs_uuid.uuid4())
{% if not attribution_sources.request_id %}_moolabs_event_id = str(_moolabs_uuid.uuid4())
{% endif %}
# REVIEW: idempotency anchor (confidence={{ entry.idempotency_anchor.confidence }})
emit_event_safe(
    event_type="{{ entry.event_type }}",
    customer_id=str({{ attribution_sources.customer_id if attribution_sources.customer_id else (attribution_sources.request_id if attribution_sources.request_id else '"unknown"') }}),
    entity_id=str({{ attribution_sources.request_id if attribution_sources.request_id else "_moolabs_event_id" }}),
    meter_slug="{{ entry.workflow_id }}",
    value={{ entry.refund_unit.derivation }},
    spans=[{
        "span_id": _moolabs_span_id,
        {% if entry.cost_micros_source %}"cost_micros": {{ entry.cost_micros_source }},
        {% endif %}{% if entry.cost_kind %}"kind": "{{ entry.cost_kind }}",
        {% endif %}
    }],
    meta={
        "workflow_id": "{{ entry.workflow_id }}",
        "feature_key": "{{ entry.workflow_id.split('.')[1] if entry.workflow_id.count('.') >= 2 else entry.workflow_id }}",
        {% if attribution_sources.consumer_agent %}"consumer_agent": {{ attribution_sources.consumer_agent }},
        {% endif %}{% if attribution_sources.request_id %}"correlation_id": {{ attribution_sources.request_id }},
        {% endif %}
    },
)
