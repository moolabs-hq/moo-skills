# ── API-key resolution ──────────────────────────────────────────────────────

@lru_cache(maxsize=1)
def _resolve_api_key() -> str:
    """Resolve MOOLABS_API_KEY from {{ sdk_key_location.strategy }}.

    Cached via lru_cache (singleton). If resolution fails, returns empty
    string — get_client() will instantiate with no key, the SDK call will
    fail, and _handle_emit_err routes per SDK_DEVELOPMENT.
    """
    env = os.environ.get("APP_ENV", "prod")
{% if sdk_key_location.strategy == "aws_secrets_manager" %}
    secret_id = f"{{ sdk_key_location.secret_id_template }}".format(env=env)
    try:
        client = boto3.client("secretsmanager", region_name="{{ sdk_key_location.region | default('us-east-1') }}")
        response = client.get_secret_value(SecretId=secret_id)
        return response["SecretString"]
    except Exception as exc:
        logger.error("moolabs.sdk_key.resolution_failed", secret_id=secret_id,
                     error=str(exc), policy="fail_open_silent_swallow")
        return ""
{% elif sdk_key_location.strategy == "gcp_secret_manager" %}
    secret_id = f"{{ sdk_key_location.secret_id_template }}".format(env=env)
    try:
        client = secretmanager.SecretManagerServiceClient()
        response = client.access_secret_version(name=secret_id)
        return response.payload.data.decode("utf-8")
    except Exception as exc:
        logger.error("moolabs.sdk_key.resolution_failed", secret_id=secret_id,
                     error=str(exc), policy="fail_open_silent_swallow")
        return ""
{% elif sdk_key_location.strategy == "vault" %}
    secret_path = f"{{ sdk_key_location.secret_id_template }}".format(env=env)
    try:
        vault = hvac.Client()
        response = vault.secrets.kv.v2.read_secret_version(path=secret_path)
        return response["data"]["data"]["api_key"]
    except Exception as exc:
        logger.error("moolabs.sdk_key.resolution_failed", secret_path=secret_path,
                     error=str(exc), policy="fail_open_silent_swallow")
        return ""
{% elif sdk_key_location.strategy == "env_var" %}
    return os.environ.get("MOOLABS_API_KEY", "")
{% elif sdk_key_location.strategy == "custom" %}
    try:
        {{ sdk_key_read_pattern | indent(8) }}
    except Exception as exc:
        logger.error("moolabs.sdk_key.resolution_failed", error=str(exc),
                     policy="fail_open_silent_swallow")
        return ""
{% endif %}


# ── client singleton ────────────────────────────────────────────────────────

@lru_cache(maxsize=1)
def get_client() -> Moolabs:
    """Return the singleton Moolabs SDK client (lru_cache = idempotent + thread-safe)."""
    return Moolabs(api_key=_resolve_api_key())


# ── error handler (env-gated single decision point) ─────────────────────────

def _handle_emit_err(event_class: str, fields: dict, err: BaseException) -> None:
    """Strict (SDK_DEVELOPMENT non-empty) -> raise so the developer fixes the call
    site. Lax (default) -> structured-log recovery rail; never silently drop."""
    if os.environ.get(_DEV_ENV_VAR):
        raise RuntimeError(
            f"moolabsclient: {event_class} emission failed "
            f"(SDK_DEVELOPMENT mode — unset to swallow): {err}"
        ) from err
    fields["error"] = str(err)
    logger.warning(f"moolabs.{event_class}.event", **fields)


# ── emit helpers (v0.3.0-rc1 ergonomic methods) ─────────────────────────────

def emit_usage_event_safe(
    *,
    event_type: str,
    customer_id: str,
    entity_id: str,
    meter_slug: str,
    value: float,
    # Well-known top-level data.* keys (canonical wire shape).
    provider: Optional[str] = None,
    model: Optional[str] = None,
    total_input_tokens: Optional[int] = None,
    total_output_tokens: Optional[int] = None,
    total_tokens: Optional[int] = None,
    latency_ms: Optional[int] = None,
    status: Optional[str] = None,
    event_id: Optional[str] = None,
    source: Optional[str] = None,
    time: Optional[datetime] = None,
    meta: Optional[dict] = None,
) -> None:
    """Wraps client.usage.ingest_event with the env-gated never-drop rail.
    Required: event_type, customer_id, entity_id, meter_slug, value (finite)."""
    if source is None:
        source = "{{ service_slug }}"
    try:
        get_client().usage.ingest_event(
            event_type=event_type, customer_id=customer_id, entity_id=entity_id,
            meter_slug=meter_slug, value=value,
            provider=provider, model=model,
            total_input_tokens=total_input_tokens,
            total_output_tokens=total_output_tokens,
            total_tokens=total_tokens, latency_ms=latency_ms, status=status,
            event_id=event_id, source=source, time=time, meta=meta,
        )
    except Exception as err:
        _handle_emit_err("usage", _usage_fallback_fields(
            event_type=event_type, customer_id=customer_id, entity_id=entity_id,
            meter_slug=meter_slug, value=value, source=source,
            provider=provider, model=model, total_input_tokens=total_input_tokens,
            total_output_tokens=total_output_tokens, total_tokens=total_tokens,
            latency_ms=latency_ms, status=status, event_id=event_id,
        ), err)


