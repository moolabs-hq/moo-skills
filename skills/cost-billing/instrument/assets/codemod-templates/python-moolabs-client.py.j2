@lru_cache(maxsize=1)
def _resolve_api_key() -> str:
    """Resolve MOOLABS_API_KEY from {{ sdk_key_location.strategy }}.

    Cached via lru_cache (singleton). If resolution fails, returns empty
    string — emit_*_safe() catches the resulting SDK error and logs a
    warning under ``moolabs.sdk_key.resolution_failed``. The workflow
    continues per the fail_open_silent_swallow contract.
    """
    env = os.environ.get("APP_ENV", "prod")
{% if sdk_key_location.strategy == "aws_secrets_manager" %}
    secret_id = f"{{ sdk_key_location.secret_id_template }}".format(env=env)
    try:
        client = boto3.client("secretsmanager", region_name="{{ sdk_key_location.region | default('us-east-1') }}")
        response = client.get_secret_value(SecretId=secret_id)
        return response["SecretString"]
    except Exception as exc:
        logger.error(
            "moolabs.sdk_key.resolution_failed",
            secret_id=secret_id,
            error=str(exc),
            policy="fail_open_silent_swallow",
        )
        return ""
{% elif sdk_key_location.strategy == "gcp_secret_manager" %}
    secret_id = f"{{ sdk_key_location.secret_id_template }}".format(env=env)
    try:
        client = secretmanager.SecretManagerServiceClient()
        response = client.access_secret_version(name=secret_id)
        return response.payload.data.decode("utf-8")
    except Exception as exc:
        logger.error("moolabs.sdk_key.resolution_failed", secret_id=secret_id, error=str(exc),
                     policy="fail_open_silent_swallow")
        return ""
{% elif sdk_key_location.strategy == "vault" %}
    secret_path = f"{{ sdk_key_location.secret_id_template }}".format(env=env)
    try:
        vault = hvac.Client()
        response = vault.secrets.kv.v2.read_secret_version(path=secret_path)
        return response["data"]["data"]["api_key"]
    except Exception as exc:
        logger.error("moolabs.sdk_key.resolution_failed", secret_path=secret_path, error=str(exc),
                     policy="fail_open_silent_swallow")
        return ""
{% elif sdk_key_location.strategy == "env_var" %}
    return os.environ.get("MOOLABS_API_KEY", "")
{% elif sdk_key_location.strategy == "custom" %}
    # Custom resolution captured at team-engineer bootstrap Q15
    try:
        {{ sdk_key_read_pattern | indent(8) }}
    except Exception as exc:
        logger.error("moolabs.sdk_key.resolution_failed", error=str(exc),
                     policy="fail_open_silent_swallow")
        return ""
{% endif %}


@lru_cache(maxsize=1)
def get_client() -> Moolabs:
    """Return the singleton Moolabs SDK client.

    Idempotent + thread-safe via lru_cache. First call performs the secret
    fetch; subsequent calls return the cached instance.
    """
    return Moolabs(api_key=_resolve_api_key())


def emit_usage_event_safe(
    event_type: str,
    subject: str,
    data: dict,
    *,
    source: str = "{{ service_slug }}",
    correlation_id: str | None = None,
) -> None:
    """Persist a usage event. Never drops the event — uses SDK when reachable,
    structured log as recovery rail when not.

    Dual transport (matches emit_cost_event_safe — both events follow the same
    never-drop contract):

      1. **Preferred — Moolabs SDK HTTP** (``client.usage.ingest_events``):
         the normal path, verified against the Phase 1.5 snapshot. Idempotency
         key in the payload makes any re-ingestion safe.

      2. **Recovery rail — structured log** (``moolabs.usage.event`` log line):
         when the SDK call raises (network out, 5xx, secret-manager outage,
         rate-limit, connection-pool exhaustion), the full event payload is
         logged with all fields flattened. The customer's log pipeline
         (CloudWatch / Datadog / Loki) retains it; recovery — auto-ingest by
         meter, or manual replay — depends on platform support that is
         tracked separately from this helper. The point is the data is
         **preserved**, not lost.

    The SDK-error-then-log path means usage events are auditable even when the
    billing-side is unreachable. "No DLQ in v1" (PM Stage 3b) remains true —
    this is not a DLQ; there's no retry queue, no delivery guarantee. It's an
    auditable record that the event was generated.

    SDK errors MUST NOT propagate. Log + continue. The workflow continues
    regardless of billing-side reachability.
    """
    payload = {
        "type": event_type,
        "subject": subject,
        "source": source,
        "data": dict(data),
    }
    if correlation_id is not None:
        payload["data"]["moolabs.correlation.id"] = correlation_id
    try:
        get_client().usage.ingest_events([payload])
        return
    except Exception as exc:
        # Recovery rail: log the full event so it is auditable + replayable.
        log_kwargs: dict[str, object] = {
            "transport": "log_recovery_rail",
            "policy": "never_drop_usage_event",
            "event_type": event_type,
            "subject": subject,
            "source": source,
            "sdk_error": str(exc),
        }
        if correlation_id is not None:
            log_kwargs["correlation_id"] = correlation_id
        for k, v in payload["data"].items():
            log_kwargs[f"data.{k}"] = v
        # Salvage trace context if there is one (correlation across the rails).
        try:
            from opentelemetry import trace as _trace

            span = _trace.get_current_span()
            if span is not None:
                ctx = span.get_span_context()
                if ctx is not None and ctx.is_valid:
                    log_kwargs["trace_id"] = format(ctx.trace_id, "032x")
                    log_kwargs["span_id"] = format(ctx.span_id, "016x")
        except Exception:
            pass
        logger.warning("moolabs.usage.event", **log_kwargs)


def emit_cost_event_safe(
    *,
    kind: str,
    tenant_id: str | None = None,
    consumer_agent: str | None = None,
    cost_micros: int | None = None,
    attributes: dict[str, str | int | float | bool] | None = None,
) -> None:
    """Persist a cost event. Never drops the event — uses OTel span when
    available, structured log as fallback.

    Sibling-pair counterpart to emit_usage_event_safe(). Both events ship
    through the SAME unified Moolabs SDK — there is no separate "acute SDK".
    Verified against moolabs-py@v0.2.0-rc9: the SDK exposes 11 flat capability
    namespaces on the client. Usage events go through ``client.usage.ingest_events``;
    cost events go through ``client.cost.ingest_events_batch`` (capability "cost"
    routes to CostEventsApi + SdkIngestApi on the acute backend).

    Two paths in priority order:

      1. **Preferred — OTel span attribute** (when an active, recording span exists):
         attributes are set on the current span and ride the existing OTLP exporter
         to the acute cost-enricher. Co-located with the trace → trivial correlation
         via ``trace_id`` / ``span_id``.

      2. **Fallback — structured log** (when no recording span is available):
         a single ``moolabs.cost.event`` log line is emitted with all attributes
         flattened. The customer's existing log pipeline (CloudWatch / Datadog / Loki)
         ships these to the same acute cost-enricher, which already ingests
         structured logs as a secondary input.

    Both paths target the same ClickHouse ``acute_analytics`` table downstream.
    **Cost data is never silently dropped** — that would corrupt the attribution
    engine for any code path the tracer doesn't sample (sampler-dropped traces,
    background workers without context propagation, dev/CI without OTel, code
    paths running before the TracerProvider is wired).

    When the unified SDK's cost-event endpoint ships, this helper's primary
    transport swaps to that endpoint (same client instance, same
    ``get_client()`` singleton); the structured-log path stays as the
    recovery rail. Call sites do not change.

    Args:
        kind: Cost-event category. Example: ``"llm-tokens"``, ``"s3-put"``,
            ``"netsuite-api-call"``. Written as ``moolabs.cost.kind`` on span,
            ``kind`` in log fallback.
        tenant_id: Tenant UUID for cross-cutting attribution. Written as
            ``moolabs.tenant.id`` (global, NOT under ``cost.*``).
        consumer_agent: Agent that incurred the cost. Written as
            ``moolabs.cost.consumer_agent``.
        cost_micros: Pre-resolved cost in micros from the upstream API
            response (NEVER invent one from token counts). Written as
            ``moolabs.cost.micros``.
        attributes: Free-form additional attributes. Each key namespaced
            under ``moolabs.cost.``.

    Fail-open contract:
        - Any exception during emission (span write OR log fallback) → log
          warning under ``moolabs.cost_emission.failed`` and return None.
          Event MAY be lost in this case (exception path), but the workflow
          continues.
    """
    try:
{% if capabilities.cost_event_direct_emit %}
        # Primary transport: unified SDK cost-event endpoint
        # ({{ capabilities.cost_event_method_path }}) — verified present in the
        # Phase 1.5 snapshot at SDK version {{ sdk_pinned_version }}.
        payload = {
            "kind": kind,
            "source": "{{ service_slug }}",
        }
        if tenant_id is not None:
            payload["tenant_id"] = str(tenant_id)
        if consumer_agent is not None:
            payload["consumer_agent"] = consumer_agent
        if cost_micros is not None:
            payload["cost_micros"] = int(cost_micros)
        if attributes:
            payload["attributes"] = dict(attributes)
        try:
            # Attribute path resolved at codemod time from snapshot:
            # {{ capabilities.cost_event_method_path }}
            {{ capabilities.cost_event_method_path | replace("client.", "get_client().") }}([payload])
            return
        except Exception as exc:
            # Fall through to log recovery rail below.
            _sdk_error = exc
{% else %}
        # Primary transport: OTel span attributes (until the unified SDK adds a
        # cost-event endpoint — Phase 1.5 snapshot shows capabilities.cost_event_direct_emit=false).
        _sdk_error = None
{% endif %}
        from opentelemetry import trace as _trace

        span = _trace.get_current_span()
{% if not capabilities.cost_event_direct_emit %}
        # An active, recording span: write attributes (preferred for span-transport path).
        if span is not None and span.is_recording():
            span.set_attribute("moolabs.cost.kind", kind)
            if tenant_id is not None:
                span.set_attribute("moolabs.tenant.id", str(tenant_id))
            if consumer_agent is not None:
                span.set_attribute("moolabs.cost.consumer_agent", consumer_agent)
            if cost_micros is not None:
                span.set_attribute("moolabs.cost.micros", int(cost_micros))
            for k, v in (attributes or {}).items():
                span.set_attribute(f"moolabs.cost.{k}", v)
            return
{% endif %}

        # Recovery rail (fires on: SDK exception above when capable,
        # OR no recording span when not capable — sampler dropped / no tracer
        # / background task / pre-init code path). Salvage trace_id when the
        # span context is valid-but-not-recording (still useful for correlation).
        trace_id: str | None = None
        span_id: str | None = None
        if span is not None:
            ctx = span.get_span_context()
            if ctx is not None and ctx.is_valid:
                trace_id = format(ctx.trace_id, "032x")
                span_id = format(ctx.span_id, "016x")

        log_kwargs: dict[str, object] = {
            "kind": kind,
            "transport": "log_fallback",
            "policy": "never_drop_cost_event",
        }
        if _sdk_error is not None:
            log_kwargs["sdk_error"] = str(_sdk_error)
        if tenant_id is not None:
            log_kwargs["tenant_id"] = str(tenant_id)
        if consumer_agent is not None:
            log_kwargs["consumer_agent"] = consumer_agent
        if cost_micros is not None:
            log_kwargs["cost_micros"] = int(cost_micros)
        if trace_id is not None:
            log_kwargs["trace_id"] = trace_id
        if span_id is not None:
            log_kwargs["span_id"] = span_id
        for k, v in (attributes or {}).items():
            log_kwargs[f"cost.{k}"] = v

        logger.info("moolabs.cost.event", **log_kwargs)
    except Exception as exc:
        logger.warning(
            "moolabs.cost_emission.failed",
            kind=kind,
            error=str(exc),
            policy="fail_open_silent_swallow",
        )
