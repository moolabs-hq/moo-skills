   Targets SDK v0.3.0-rc1 unified-ingest ergonomic methods. Every per-callsite
   emission MUST go through emit_usage_event_safe / emit_cost_event_safe /
   emit_event_safe — NEVER instantiate Moolabs(...) inline.

   Variables expected:
     service_slug                — e.g. "<your-service>"
     signoff_chain_hashes        — list of {stage, file, sha256} entries
     sdk_key_location.strategy   — aws_secrets_manager | gcp_secret_manager | vault | env_var | custom
     sdk_key_location.region     — for AWS (e.g. "us-east-1")
     sdk_key_location.secret_id_template — e.g. "{env}/moolabs/sdk-api-key"
     sdk_key_read_pattern        — verbatim code snippet (when strategy=custom)
     sdk_pinned_version          — from Phase 1.5 snapshot (resolved tag; must be >= v0.3.0-rc1)
     telemetry.mode              — brownfield | greenfield
#}
"""Moolabs SDK client for {{ service_slug }}.

Module-level billing-emission singleton, wired by /cost-billing-instrument.
Generated {{ generated_at }} per the signed gates:
{% for h in signoff_chain_hashes %}  - {{ h.stage }}: {{ h.file.split('/')[-1] }} (sha {{ h.sha256[:8] }})
{% endfor %}
SDK version: {{ sdk_pinned_version | default("v0.3.0-rc1") }}  (unified-ingest ergonomic methods)

Three emission helpers mapping 1:1 to the v0.3.0 SDK methods:
  emit_usage_event_safe(...)  -> client.usage.ingest_event(...)
  emit_cost_event_safe(...)   -> client.cost.ingest_event(...)
  emit_event_safe(...)        -> client.events.ingest(...)   # sibling-pair, dual-lane

tenant_id is intentionally absent from every helper signature — the server
derives tenant identity from the API key (never pass tenant_id — the server
derives it from the key).
entity_id is the threading key for sibling-pair join downstream.

Error handling is env-gated (single decision point in _handle_emit_err):
  SDK_DEVELOPMENT non-empty -> raise on any SDK error (validation or transport)
                               so the developer sees the failure at the call site.
  SDK_DEVELOPMENT unset     -> structured-log recovery rail; the emission is
                               never silently dropped. Default for prod.

THIS IS THE ONLY PLACE THAT INSTANTIATES THE MOOLABS CLIENT.
"""

from __future__ import annotations

import os
import re
from functools import lru_cache
from typing import TYPE_CHECKING, Any

{# Phase 1.7 env-wire (NEW v0.3 env-routing migration):
   env_config.mode               — "modify" | "stub"
   env_config.settings_import_path — e.g. "app.config" or "app.services.moolabs_settings"
   env_config.api_key_accessor   — e.g. "get_settings().moolabs_api_key.get_secret_value()"

   The v0.2-era strategy-branched _resolve_api_key (boto3/hvac/google.cloud)
   is gone. The customer's Settings class is now RESPONSIBLE for resolving
   the secret from whatever store they use (Vault/AWS/etc) — the helper
   just reads `get_settings().moolabs_api_key`.
#}
import structlog

# Import the customer's settings layer (or the generated stub).
from {{ env_config.settings_import_path }} import get_settings

if TYPE_CHECKING:
    # Annotation-only imports — keep `moolabs` out of module-import so this file
    # imports before the SDK is installed (lazy import inside get_client()).
    from datetime import datetime

    from moolabs import Moolabs

logger = structlog.get_logger(__name__)

# Env-gated strict/lax mode — same var name as the Go helper for cross-language
# parity. Non-empty -> raise (dev mode); unset -> log-rail swallow (prod).
_DEV_ENV_VAR = "SDK_DEVELOPMENT"

# Defense-in-depth: never let an API key reach logs/exceptions verbatim if an SDK
# error echoes it. Scrub secret-shaped tokens at the rail's own boundary.
_SECRET_TOKEN_RE = re.compile(
    r"\b(?:sk|rk)_(?:live|test)_[A-Za-z0-9_]+|\bwhsec_[A-Za-z0-9_]+|\bmoo_[a-z]+_[A-Za-z0-9_]+"
)


def _scrub_secrets(text: str) -> str:
    return _SECRET_TOKEN_RE.sub("[REDACTED]", text)

{% if telemetry.mode == "brownfield" %}
# Brownfield directive: this service already has a live TracerProvider.
# Do NOT register a second provider — get spans via
# ``opentelemetry.trace.get_tracer(__name__)`` where needed.
{% endif %}


# ── API-key resolution ──────────────────────────────────────────────────────

@lru_cache(maxsize=1)
def _resolve_api_key() -> str:
    """Read MOOLABS_API_KEY from the customer's settings layer.

    The customer's Settings class (or the generated stub at
    {{ env_config.stub_emit_path if env_config.mode == "stub" else env_config.settings_import_path }})
    owns secret resolution — whether it pulls from Vault, AWS Secrets
    Manager, env vars, or a hardcoded value. This helper does not care.
    """
    return {{ env_config.api_key_accessor }}


# ── client singleton ────────────────────────────────────────────────────────

@lru_cache(maxsize=1)
def get_client() -> Moolabs:
    """Return the singleton Moolabs SDK client (cached; idempotent, thread-safe)."""
    from moolabs import Moolabs  # noqa: PLC0415 (lazy; SDK optional at import time)

    return Moolabs(api_key=_resolve_api_key())


# ── error handler (env-gated single decision point) ─────────────────────────

def _handle_emit_err(event_class: str, fields: dict, err: BaseException) -> None:
    """Strict (SDK_DEVELOPMENT non-empty) -> raise so the developer fixes the call
    site. Lax (default) -> structured-log recovery rail; never silently drop."""
    if os.environ.get(_DEV_ENV_VAR):
        raise RuntimeError(
            f"moolabsclient: {event_class} emission failed "
            f"(SDK_DEVELOPMENT mode — unset to swallow): {_scrub_secrets(str(err))}"
        ) from err
    fields["error"] = _scrub_secrets(str(err))
    logger.warning(f"moolabs.{event_class}.event", **fields)


# ── emit helpers (v0.3.0-rc1 ergonomic methods) ─────────────────────────────

def emit_usage_event_safe(
    *,
    event_type: str,
    customer_id: str,
    entity_id: str,
    meter_slug: str,
    value: float,
    # Well-known top-level data.* keys (canonical wire shape).
    provider: str | None = None,
    model: str | None = None,
    total_input_tokens: int | None = None,
    total_output_tokens: int | None = None,
    total_tokens: int | None = None,
    latency_ms: int | None = None,
    status: str | None = None,
    event_id: str | None = None,
    source: str | None = None,
    time: datetime | None = None,
    meta: dict | None = None,
) -> None:
    """Wraps client.usage.ingest_event with the env-gated never-drop rail.
    Required: event_type, customer_id, entity_id, meter_slug, value (finite)."""
    if source is None:
        source = "{{ service_slug }}"
    try:
        get_client().usage.ingest_event(
            event_type=event_type, customer_id=customer_id, entity_id=entity_id,
            meter_slug=meter_slug, value=value,
            provider=provider, model=model,
            total_input_tokens=total_input_tokens,
            total_output_tokens=total_output_tokens,
            total_tokens=total_tokens, latency_ms=latency_ms, status=status,
            event_id=event_id, source=source, time=time, meta=meta,
        )
    except Exception as err:
        _handle_emit_err("usage", _usage_fallback_fields(
            event_type=event_type, customer_id=customer_id, entity_id=entity_id,
            meter_slug=meter_slug, value=value, source=source,
            provider=provider, model=model, total_input_tokens=total_input_tokens,
            total_output_tokens=total_output_tokens, total_tokens=total_tokens,
            latency_ms=latency_ms, status=status, event_id=event_id,
        ), err)


