def emit_event_safe(
    *,
    event_type: str,
    customer_id: str,
    entity_id: str,
    meter_slug: str | None = None,
    value: float | None = None,
    spans: list[dict] | None = None,
    provider: str | None = None,
    model: str | None = None,
    total_input_tokens: int | None = None,
    total_output_tokens: int | None = None,
    total_tokens: int | None = None,
    latency_ms: int | None = None,
    status: str | None = None,
    event_id: str | None = None,
    source: str | None = None,
    time: datetime | None = None,
    meta: dict | None = None,
) -> None:
    """Wraps client.events.ingest (dual-lane). Use for sibling-pair
    emission. Required: event_type, customer_id, entity_id + at least one of
    (meter_slug+value) or non-empty spans — the SDK raises ValueError on empty-
    lane synchronously."""
    if source is None:
        source = "{{ service_slug }}"
    try:
        get_client().events.ingest(
            event_type=event_type, customer_id=customer_id, entity_id=entity_id,
            meter_slug=meter_slug, value=value, spans=spans,
            provider=provider, model=model,
            total_input_tokens=total_input_tokens,
            total_output_tokens=total_output_tokens,
            total_tokens=total_tokens, latency_ms=latency_ms, status=status,
            event_id=event_id, source=source, time=time, meta=meta,
        )
    except Exception as err:
        _handle_emit_err("event", _event_fallback_fields(
            event_type=event_type, customer_id=customer_id, entity_id=entity_id,
            meter_slug=meter_slug, value=value, spans=spans, source=source,
            provider=provider, model=model, total_tokens=total_tokens,
            latency_ms=latency_ms, status=status, event_id=event_id,
        ), err)


# ── fallback field builders (recovery-rail payloads) ────────────────────────

def _usage_fallback_fields(**kwargs: Any) -> dict:
    fields = {
        "transport": "log_recovery_rail",
        "policy": "never_drop_usage_event",
    }
    for k, v in kwargs.items():
        if v is not None:
            fields[k] = v
    return fields


def _cost_fallback_fields(spans: list[dict], **kwargs: Any) -> dict:
    fields = {
        "transport": "log_recovery_rail",
        "policy": "never_drop_cost_event",
        "span_count": len(spans) if spans else 0,
    }
    for k, v in kwargs.items():
        if v is not None:
            fields[k] = v
    return fields


def _event_fallback_fields(spans: list[dict] | None, **kwargs: Any) -> dict:
    fields = {
        "transport": "log_recovery_rail",
        "policy": "never_drop_event",
        "span_count": len(spans) if spans else 0,
    }
    for k, v in kwargs.items():
        if v is not None:
            fields[k] = v
    return fields
