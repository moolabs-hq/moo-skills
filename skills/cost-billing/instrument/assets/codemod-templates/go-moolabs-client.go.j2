}

func usageLogFields(e UsageEvent, eventID string) map[string]any {
	f := map[string]any{
		"transport": "log_recovery_rail",
		"policy":    "never_drop_usage_event",
		"event_id":  eventID,
		"type":      e.EventType,
		"subject":   e.Subject,
	}
	putStr(f, "tenant_id", e.TenantID)
	putStr(f, "customer_id", e.CustomerID)
	putStr(f, "feature_key", e.FeatureKey)
	putStr(f, "feature_id", e.FeatureID)
