func usageFallback(a moolabs.IngestEventArgs) map[string]any {
	f := map[string]any{
		"transport":   "log_recovery_rail",
		"policy":      "never_drop_usage_event",
		"event_type":  a.EventType,
		"customer_id": a.CustomerID,
		"entity_id":   a.EntityID,
		"meter_slug":  a.MeterSlug,
		"value":       a.Value,
		"source":      a.Source,
	}
	putStrPtr(f, "provider", a.Provider)
	putStrPtr(f, "model", a.Model)
	putInt64Ptr(f, "total_input_tokens", a.TotalInputTokens)
	putInt64Ptr(f, "total_output_tokens", a.TotalOutputTokens)
	putInt64Ptr(f, "total_tokens", a.TotalTokens)
	putInt64Ptr(f, "latency_ms", a.LatencyMs)
	putStrPtr(f, "status", a.Status)
	if a.EventID != "" {
		f["event_id"] = a.EventID
	}
	return f
}

