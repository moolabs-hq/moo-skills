// ---- cost events ------------------------------------------------------------

// CostEvent is the sibling-pair of UsageEvent. usage_event_id links a cost event
// back to its usage sibling so the two join downstream.
type CostEvent struct {
	Kind           string
	Provider       string
	CostMicros     int64
	Currency       string
	TenantID       string
	CustomerID     string
	FeatureKey     string
	FeatureID      string
	RequestID      string
	UsageEventID   string
	Environment    string
	IdempotencyKey string
}

func EmitCostEventSafe(ctx context.Context, e CostEvent) {
{% if capabilities.cost_event_direct_emit %}
	// PRIMARY (snapshot cost_event_direct_emit=true): direct SDK cost emit.
	// tenant_id + idempotency_key are REQUIRED on the wire — refuse-to-emit if
	// tenant_id is missing (the SDK would 422 on validation).
	if e.TenantID == "" {
		logEvent("moolabs.cost_emission.skipped_no_tenant_id", map[string]any{
			"kind":   e.Kind,
			"reason": "CostEventIngest requires tenant_id; bind it in Phase 1.6",
		})
		return
	}
	idem := e.IdempotencyKey
	if idem == "" {
		idem = newID()
	}
	provider := e.Provider
	if provider == "" {
		provider = e.Kind
	}
	currency := e.Currency
	if currency == "" {
		currency = "USD"
	}
	amount := float32(e.CostMicros) / 1e6

	ce := moolabs.NewCostEventIngest(
		e.TenantID, idem, provider,
		moolabs.ObservedTotalCost{Float32: &amount},
		currency,
		moolabs.ReportingTotalCost{Float32: &amount},
		time.Now().UTC(),
	)
	if e.CustomerID != "" {
		ce.CustomerId = &e.CustomerID
	}
	if e.FeatureID != "" {
		ce.FeatureId = &e.FeatureID
	}
	if e.RequestID != "" {
		ce.RequestId = &e.RequestID
	}
	if e.UsageEventID != "" {
		ce.UsageEventId = &e.UsageEventID
	}
	if e.Environment != "" {
		ce.Environment = &e.Environment
	}
	// feature_key (slug) rides in tags — ACUTE's mapping engine reads it; feature_id
	// (UUID) is the top-level column.
	if e.FeatureKey != "" {
		ce.Tags = map[string]interface{}{"feature_key": e.FeatureKey}
	}

	if cli, err := getClient(); err == nil {
		req := moolabs.NewBatchIngestRequest([]moolabs.CostEventIngest{*ce})
		if _, _, ierr := cli.Cost.IngestEventsBatch(ctx).BatchIngestRequest(*req).Execute(); ierr == nil {
			return
		}
	}
	logEvent("moolabs.cost.event", costLogFields(e, idem))
{% else %}
	// PRIMARY (snapshot cost_event_direct_emit=false): the structured-log recovery
	// rail. (Brownfield OTel-span emission — go.opentelemetry.io/otel — is the
	// enhancement here; the helper auto-upgrades to the direct SDK call once a
	// future Phase 1.5 snapshot reports the cost endpoint. Call sites do not change.)
	logEvent("moolabs.cost.event", costLogFields(e, e.IdempotencyKey))
{% endif %}
}

func costLogFields(e CostEvent, idem string) map[string]any {
	f := map[string]any{
		"transport":   "log_recovery_rail",
		"policy":      "never_drop_cost_event",
		"kind":        e.Kind,
		"cost_micros": e.CostMicros,
	}
	putStr(f, "idempotency_key", idem)
	putStr(f, "tenant_id", e.TenantID)
	putStr(f, "customer_id", e.CustomerID)
	putStr(f, "feature_key", e.FeatureKey)
	putStr(f, "feature_id", e.FeatureID)
	putStr(f, "request_id", e.RequestID)
	putStr(f, "usage_event_id", e.UsageEventID)
	putStr(f, "currency", e.Currency)
	return f
}
