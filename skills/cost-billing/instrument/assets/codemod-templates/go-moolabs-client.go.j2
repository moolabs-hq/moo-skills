	putStr(data, "moolabs.customer.id", e.CustomerID)
	putStr(data, "moolabs.feature.key", e.FeatureKey)
	putStr(data, "moolabs.feature.id", e.FeatureID)
	putStr(data, "moolabs.request.id", e.RequestID)
	putStr(data, "moolabs.consumer.agent", e.ConsumerAgent)
	putStr(data, "moolabs.correlation.id", e.CorrelationID)

	evt := map[string]any{
		"id":      eventID,
		"source":  "{{ service_slug }}",
		"type":    e.EventType,
