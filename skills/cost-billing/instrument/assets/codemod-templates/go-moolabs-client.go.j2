// ---- shared helpers ---------------------------------------------------------

// newID returns a random hex id (CloudEvents id / idempotency fallback).
func newID() string {
	b := make([]byte, 16)
	if _, err := rand.Read(b); err != nil {
		return "evt-" + time.Now().UTC().Format("20060102T150405.000000000")
	}
	return hex.EncodeToString(b)
}

// logEvent is the structured-log recovery rail. Both helpers fall back to it so
// an emission is never silently dropped.
func logEvent(msg string, fields map[string]any) {
	b, _ := json.Marshal(fields)
	log.Printf("%s %s", msg, string(b))
}

func putStr(m map[string]any, k, v string) {
	if v != "" {
		m[k] = v
	}
}

